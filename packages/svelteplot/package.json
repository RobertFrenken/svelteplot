{
    "name": "svelteplot",
    "version": "0.14.2",
    "description": "A Svelte-native data visualization framework based on the layered grammar of graphics principles.",
    "keywords": [
        "svelte",
        "data visualization",
        "plotting",
        "data analysis",
        "datavis",
        "dataviz",
        "grammar of graphics",
        "interactive visualization"
    ],
    "homepage": "https://svelteplot.dev",
    "bugs": {
        "url": "https://github.com/svelteplot/svelteplot/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/svelteplot/svelteplot.git"
    },
    "license": "ISC",
    "author": {
        "name": "Gregor Aisch",
        "email": "gka@users.noreply.github.com"
    },
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js"
        },
        "./*.js": {
            "import": "./dist/*.js"
        },
        "./*.svelte": {
            "import": "./dist/*.svelte"
        },
        "./core/*.svelte": {
            "import": "./dist/core/*.svelte"
        },
        "./marks/*.svelte": {
            "import": "./dist/marks/*.svelte"
        },
        "./transforms": {
            "import": "./dist/transforms/index.js"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "scripts": {
        "prepack": "npx svelte-package --input src && node scripts/fix-js-imports.js dist",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "d3-array": "^3.2.4",
        "d3-color": "^3.1.0",
        "d3-contour": "^4.0.2",
        "d3-delaunay": "^6.0.4",
        "d3-format": "^3.1.2",
        "d3-geo": "^3.1.1",
        "d3-interpolate": "^3.0.1",
        "d3-path": "^3.1.0",
        "d3-quadtree": "^3.0.1",
        "d3-random": "^3.0.1",
        "d3-scale": "^4.0.2",
        "d3-scale-chromatic": "^3.1.0",
        "d3-shape": "^3.2.0",
        "d3-time": "^3.1.0",
        "es-toolkit": "^1.45.1",
        "fast-equals": "^6.0.0",
        "interval-tree-1d": "^1.0.4",
        "merge-deep": "^3.0.3"
    },
    "devDependencies": {
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "6.2.4",
        "@types/d3-array": "^3.2.2",
        "@types/d3-color": "^3.1.3",
        "@types/d3-contour": "^3.0.6",
        "@types/d3-delaunay": "^6.0.4",
        "@types/d3-geo": "^3.1.0",
        "@types/d3-interpolate": "^3.0.4",
        "@types/d3-path": "^3.1.1",
        "@types/d3-quadtree": "^3.0.6",
        "@types/d3-random": "^3.0.3",
        "@types/d3-scale": "^4.0.9",
        "@types/d3-scale-chromatic": "^3.1.0",
        "@types/d3-shape": "^3.1.8",
        "@types/geojson": "^7946.0.16",
        "@types/topojson": "^3.2.6",
        "@types/topojson-client": "^3.1.5",
        "@testing-library/svelte": "^5.3.1",
        "@testing-library/user-event": "^14.6.1",
        "jsdom": "^27.4.0",
        "resize-observer-polyfill": "^1.5.1",
        "svelte": "5",
        "typescript": "^5.9.3",
        "tslib": "^2.8.1",
        "vite": "^7.3.1",
        "vitest": "^4.1.4",
        "vitest-matchmedia-mock": "^2.0.3"
    },
    "peerDependencies": {
        "svelte": "^5.43.0"
    }
}
